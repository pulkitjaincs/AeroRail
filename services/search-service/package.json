{
  "name": "@aerorail/search-service",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch src/index.ts",
    "build": "tsc",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "seed": "cross-env NODE_ENV=development tsx src/scripts/seed.ts",
    "prisma:generate": "prisma generate --schema=../auth-service/prisma/schema.prisma"
  },
  "dependencies": {
    "@aerorail/db": "workspace:*",
    "@aerorail/errors": "workspace:*",
    "@aerorail/logger": "workspace:*",
    "@aerorail/middleware": "workspace:*",
    "@aerorail/redis": "workspace:*",
    "@aerorail/server": "workspace:*",
    "@aerorail/types": "workspace:*",
    "@prisma/client": "^5.12.0",
    "dotenv": "^16.4.0",
    "express": "^4.20.0 || ^5.0.0-beta.1",
    "ioredis": "^5.4.0",
    "neo4j-driver": "^5.18.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^20.0.0",
    "cross-env": "^10.1.0",
    "prisma": "^5.12.0",
    "tsx": "^4.7.0",
    "typescript": "^5.0.0"
  }
}
